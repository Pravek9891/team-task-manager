# ==========================================
# Team Task Manager — Backend Environment
# ==========================================
# Copy this file to .env and fill in your values.

# Django
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite for local dev — use postgres:// for production)
DATABASE_URL=sqlite:///db.sqlite3

# CORS — Add your React dev server and production frontend URL
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# For Railway PostgreSQL, the DATABASE_URL will look like:
# DATABASE_URL=postgres://user:password@host:5432/dbname
