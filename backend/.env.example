# ==========================================
# Team Task Manager — Backend Environment
# ==========================================
# Copy this file to .env and fill in your values.

# Django core
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS — add your React dev server and production frontend URL
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173

# Database: SQLite is used by default (no configuration needed).
# The db.sqlite3 file is created automatically in the backend/ directory.
# To switch to a different database engine in the future, modify DATABASES in settings.py.
